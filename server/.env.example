# Copy to .env and fill in. NEVER commit the real .env.

# Bootstrap password for the first ('admin') user — you sign in with it
# from the phone and the desktop app.
STICKERS_PASSWORD=change-me

# Bootstrap API token for the 'admin' user. Generate: openssl rand -hex 32
STICKERS_TOKEN=generate-with-openssl-rand-hex-32

# Allow open sign-ups (multi-user). The very first user can always register
# even when this is false.
STICKERS_REGISTRATION=false
